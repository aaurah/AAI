NODE_ENV=development
PORT=3000

SESSION_SECRET=change-this-to-a-long-random-string-in-production
SESSION_MAX_AGE_HOURS=8

DB_DIALECT=sqlite
DB_STORAGE=./data/admin.db

# Optional: PostgreSQL connection string (overrides SQLite when set)
# DATABASE_URL=postgres://user:pass@localhost:5432/aai_admin

APP_NAME=AAI Admin Panel
APP_URL=http://localhost:3000

# ── GitHub OAuth ────────────────────────────────────────────────────────────────
# Create an OAuth App at: https://github.com/settings/developers
# Homepage URL:       http://localhost:3000
# Callback URL:       http://localhost:3000/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── GitHub Webhook ──────────────────────────────────────────────────────────────
# Set in your GitHub repo Settings → Webhooks
# Payload URL: http://your-server/github/webhook
# Content type: application/json
# Secret: a random string you generate
GITHUB_WEBHOOK_SECRET=

# ── Rate limiting ───────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=10

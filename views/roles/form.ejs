<%- include('../partials/header', { title }) %>

<div class="d-flex align-items-center mb-4">
  <a href="/roles" class="btn btn-sm btn-outline-secondary me-3"><i class="fa-solid fa-arrow-left"></i></a>
  <h2 class="page-title mb-0"><%= role ? 'Edit Role' : 'Create Role' %></h2>
</div>

<div class="row">
  <div class="col-lg-8">
    <div class="card card-dark">
      <div class="card-body">
        <form method="POST" action="/roles/<%= role ? role.id + '/edit' : 'create' %>">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <div class="row g-3 mb-4">
            <div class="col-md-6">
              <label class="form-label">Role Name <span class="text-danger">*</span></label>
              <input type="text" name="name" class="form-control" value="<%= role ? role.name : '' %>" required maxlength="50" />
            </div>
            <div class="col-md-3">
              <label class="form-label">Color</label>
              <input type="color" name="color" class="form-control form-control-color w-100" value="<%= role ? role.color : '#6c757d' %>" />
            </div>
            <div class="col-12">
              <label class="form-label">Description</label>
              <input type="text" name="description" class="form-control" value="<%= role ? (role.description || '') : '' %>" maxlength="255" />
            </div>
          </div>

          <h6 class="text-muted text-uppercase fw-semibold mb-3">Permissions</h6>

          <%
            const grouped = {};
            permissions.forEach(p => {
              if (!grouped[p.resource]) grouped[p.resource] = [];
              grouped[p.resource].push(p);
            });
            const assignedIds = role ? (role.Permissions || []).map(p => p.id) : [];
          %>

          <div class="row g-3">
            <% Object.entries(grouped).forEach(([resource, perms]) => { %>
            <div class="col-md-6">
              <div class="perm-group">
                <div class="perm-group-header text-uppercase small fw-semibold text-muted"><%= resource %></div>
                <% perms.forEach(p => { %>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="permissions" value="<%= p.id %>"
                    id="perm_<%= p.id %>" <%= assignedIds.includes(p.id) ? 'checked' : '' %> />
                  <label class="form-check-label" for="perm_<%= p.id %>">
                    <code><%= p.action %></code>
                    <span class="text-muted small ms-1">— <%= p.description %></span>
                  </label>
                </div>
                <% }) %>
              </div>
            </div>
            <% }) %>
          </div>

          <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk me-1"></i><%= role ? 'Save Changes' : 'Create Role' %></button>
            <a href="/roles" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<%- include('../partials/header', { title }) %>

<div class="d-flex align-items-center justify-content-between mb-4">
  <h2 class="page-title mb-0"><i class="fa-solid fa-bell me-2"></i>Notifications</h2>
  <button class="btn btn-sm btn-outline-secondary" id="markAllReadBtn">
    <i class="fa-solid fa-check-double me-1"></i>Mark All Read
  </button>
</div>

<div class="card card-dark">
  <div class="card-body p-0">
    <% if (notifications.length) { %>
    <div class="list-group list-group-flush">
      <% notifications.forEach(n => { %>
      <div class="list-group-item list-group-item-dark d-flex align-items-start gap-3 py-3 <%= !n.isRead ? 'unread-notif' : '' %>" data-id="<%= n.id %>">
        <div class="notif-icon-wrap bg-<%= n.type %>-subtle rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:36px;height:36px">
          <i class="fa-solid <%= n.icon %> text-<%= n.type %>"></i>
        </div>
        <div class="flex-grow-1">
          <div class="fw-semibold <%= !n.isRead ? 'text-white' : 'text-muted' %>"><%= n.title %></div>
          <% if (n.message) { %><div class="small text-muted mt-1"><%= n.message %></div><% } %>
          <div class="text-muted mt-1" style="font-size:.72rem"><%= moment(n.createdAt).fromNow() %></div>
        </div>
        <div class="d-flex gap-1 flex-shrink-0">
          <% if (!n.isRead) { %>
          <button class="btn btn-sm btn-outline-secondary mark-read-btn" data-id="<%= n.id %>" title="Mark read">
            <i class="fa-solid fa-check"></i>
          </button>
          <% } %>
          <button class="btn btn-sm btn-outline-danger delete-notif-btn" data-id="<%= n.id %>" title="Delete">
            <i class="fa-solid fa-times"></i>
          </button>
        </div>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <div class="text-center text-muted py-5">
      <i class="fa-solid fa-bell-slash" style="font-size:3rem;opacity:.3"></i>
      <p class="mt-3">No notifications.</p>
    </div>
    <% } %>
  </div>
</div>

<% const extraScripts = `<script>
document.querySelectorAll('.mark-read-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    await fetch('/notifications/' + btn.dataset.id + '/read', {
      method:'POST', headers:{'Content-Type':'application/json','X-CSRF-Token':'<%= csrfToken %>'}
    });
    btn.closest('.list-group-item').classList.remove('unread-notif');
    btn.remove();
  });
});
document.querySelectorAll('.delete-notif-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    await fetch('/notifications/' + btn.dataset.id + '/delete', {
      method:'POST', headers:{'Content-Type':'application/json','X-CSRF-Token':'<%= csrfToken %>'}
    });
    btn.closest('.list-group-item').remove();
  });
});
document.getElementById('markAllReadBtn').addEventListener('click', async () => {
  await fetch('/notifications/read-all', {
    method:'POST', headers:{'Content-Type':'application/json','X-CSRF-Token':'<%= csrfToken %>'}
  });
  document.querySelectorAll('.unread-notif').forEach(el => el.classList.remove('unread-notif'));
  document.querySelectorAll('.mark-read-btn').forEach(b => b.remove());
});
<\/script>`; %>

<%- include('../partials/footer') %>

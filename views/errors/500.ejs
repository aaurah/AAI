<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8" />
  <title>500 Server Error</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="login-body">
<div class="login-wrapper text-center">
  <h1 class="display-1 text-danger fw-bold">500</h1>
  <h3>Internal Server Error</h3>
  <p class="text-muted">Something went wrong on our end.</p>
  <% if (error && error.message) { %>
  <pre class="text-danger small text-start mt-3 p-3 bg-dark rounded"><%= error.message %></pre>
  <% } %>
  <a href="/dashboard" class="btn btn-primary mt-3">← Back to Dashboard</a>
</div>
</body>
</html>

<%- include('../partials/header', { title }) %>

<div class="d-flex align-items-center justify-content-between mb-4">
  <h2 class="page-title mb-0"><i class="fa-solid fa-scroll me-2"></i>Audit Log <span class="badge bg-secondary fs-6"><%= count.toLocaleString() %></span></h2>
</div>

<!-- Filters -->
<div class="card card-dark mb-4">
  <div class="card-body py-3">
    <form method="GET" action="/audit" class="row g-2 align-items-end">
      <div class="col-sm-3">
        <input type="text" name="action" class="form-control form-control-sm" placeholder="Action (e.g. login)" value="<%= filters.action || '' %>" />
      </div>
      <div class="col-sm-2">
        <input type="text" name="user" class="form-control form-control-sm" placeholder="Username" value="<%= filters.user || '' %>" />
      </div>
      <div class="col-sm-2">
        <select name="status" class="form-select form-select-sm">
          <option value="">All Status</option>
          <option value="success" <%= filters.status === 'success' ? 'selected' : '' %>>Success</option>
          <option value="failure" <%= filters.status === 'failure' ? 'selected' : '' %>>Failure</option>
          <option value="warning" <%= filters.status === 'warning' ? 'selected' : '' %>>Warning</option>
        </select>
      </div>
      <div class="col-sm-2">
        <select name="severity" class="form-select form-select-sm">
          <option value="">All Severity</option>
          <option value="low" <%= filters.severity === 'low' ? 'selected' : '' %>>Low</option>
          <option value="medium" <%= filters.severity === 'medium' ? 'selected' : '' %>>Medium</option>
          <option value="high" <%= filters.severity === 'high' ? 'selected' : '' %>>High</option>
          <option value="critical" <%= filters.severity === 'critical' ? 'selected' : '' %>>Critical</option>
        </select>
      </div>
      <div class="col-auto d-flex gap-1">
        <input type="date" name="from" class="form-control form-control-sm" value="<%= filters.from || '' %>" />
        <input type="date" name="to" class="form-control form-control-sm" value="<%= filters.to || '' %>" />
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-primary"><i class="fa-solid fa-filter me-1"></i>Filter</button>
        <a href="/audit" class="btn btn-sm btn-outline-secondary ms-1">Reset</a>
      </div>
    </form>
  </div>
</div>

<div class="card card-dark">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-dark table-hover table-sm align-middle mb-0">
        <thead>
          <tr>
            <th>Time</th><th>Action</th><th>User</th><th>Resource</th><th>Status</th><th>Severity</th><th>IP</th>
          </tr>
        </thead>
        <tbody>
          <% logs.forEach(log => { %>
          <tr>
            <td class="text-muted" style="white-space:nowrap">
              <span title="<%= log.createdAt %>"><%= moment(log.createdAt).format('MMM D HH:mm:ss') %></span>
            </td>
            <td><code class="text-info small"><%= log.action %></code></td>
            <td>
              <% if (log.user) { %>
              <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(log.username) %>&background=3b4a6b&color=fff&size=20" class="avatar-xs me-1" alt="" />
              <% } %>
              <span class="small"><%= log.username || '—' %></span>
            </td>
            <td class="small text-muted">
              <% if (log.resource) { %><%= log.resource %><% if (log.resourceId) { %>:<span class="text-warning"><%= log.resourceId %></span><% } %><% } else { %>—<% } %>
            </td>
            <td>
              <span class="badge bg-<%= log.status === 'success' ? 'success' : log.status === 'failure' ? 'danger' : 'warning' %>">
                <%= log.status %>
              </span>
            </td>
            <td><span class="badge sev-<%= log.severity %>"><%= log.severity %></span></td>
            <td class="text-muted small"><%= log.ipAddress || '—' %></td>
          </tr>
          <% }) %>
          <% if (!logs.length) { %>
          <tr><td colspan="7" class="text-center text-muted py-4">No audit events match your filters.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <% if (pages > 1) { %>
  <div class="card-footer d-flex justify-content-between align-items-center">
    <span class="text-muted small">Page <%= page %> of <%= pages %> (<%= count.toLocaleString() %> total)</span>
    <nav><ul class="pagination pagination-sm mb-0">
      <% if (page > 1) { %><li class="page-item"><a class="page-link" href="?page=<%= page-1 %>">‹</a></li><% } %>
      <% const start = Math.max(1, page-2), end = Math.min(pages, page+2); %>
      <% for (let i = start; i <= end; i++) { %>
      <li class="page-item <%= i === page ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= i %>&action=<%= filters.action||'' %>&user=<%= filters.user||'' %>&status=<%= filters.status||'' %>&severity=<%= filters.severity||'' %>"><%= i %></a>
      </li>
      <% } %>
      <% if (page < pages) { %><li class="page-item"><a class="page-link" href="?page=<%= page+1 %>">›</a></li><% } %>
    </ul></nav>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>

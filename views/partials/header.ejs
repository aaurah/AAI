<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — <%= appName %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body>

<nav id="sidebar" class="sidebar d-flex flex-column">
  <div class="sidebar-brand">
    <i class="fa-solid fa-shield-halved brand-icon"></i>
    <span class="brand-text"><%= appName %></span>
  </div>

  <ul class="nav flex-column sidebar-nav">
    <li class="nav-item">
      <a class="nav-link <%= title === 'Dashboard' ? 'active' : '' %>" href="/dashboard">
        <i class="fa-solid fa-gauge-high"></i> Dashboard
      </a>
    </li>
    <% const _hasPermission = (perm) => currentUser && (currentUser.isSuperAdmin || (currentUser.role && currentUser.role.Permissions && currentUser.role.Permissions.some(p => p.name === perm || p.name === '*'))); %>
    <li class="nav-section">USER MANAGEMENT</li>
    <% if (_hasPermission('users:read')) { %>
    <li class="nav-item">
      <a class="nav-link <%= title && title.includes('User') ? 'active' : '' %>" href="/users">
        <i class="fa-solid fa-users"></i> Users
      </a>
    </li>
    <% } %>
    <% if (_hasPermission('roles:read')) { %>
    <li class="nav-item">
      <a class="nav-link <%= title && title.includes('Role') ? 'active' : '' %>" href="/roles">
        <i class="fa-solid fa-user-shield"></i> Roles & Permissions
      </a>
    </li>
    <% } %>
    <li class="nav-section">SECURITY</li>
    <li class="nav-item">
      <a class="nav-link <%= title === 'API Keys' ? 'active' : '' %>" href="/apikeys">
        <i class="fa-solid fa-key"></i> API Keys
      </a>
    </li>
    <% if (_hasPermission('audit:read')) { %>
    <li class="nav-item">
      <a class="nav-link <%= title === 'Audit Log' ? 'active' : '' %>" href="/audit">
        <i class="fa-solid fa-scroll"></i> Audit Log
      </a>
    </li>
    <% } %>
    <% if (_hasPermission('settings:read')) { %>
    <li class="nav-section">CONFIGURATION</li>
    <li class="nav-item">
      <a class="nav-link <%= title === 'Settings' ? 'active' : '' %>" href="/settings">
        <i class="fa-solid fa-gear"></i> Settings
      </a>
    </li>
    <% } %>
  </ul>

  <div class="sidebar-footer">
    <div class="user-info">
      <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(currentUser ? currentUser.fullName() : 'U') %>&background=3b4a6b&color=fff&size=32" class="avatar-sm" alt="avatar" />
      <div class="user-meta">
        <span class="user-name"><%= currentUser ? currentUser.fullName() : '' %></span>
        <span class="user-role"><%= currentUser && currentUser.role ? currentUser.role.name : (currentUser && currentUser.isSuperAdmin ? 'Super Admin' : '') %></span>
      </div>
    </div>
    <a href="/auth/profile" class="btn btn-sm btn-outline-secondary me-1" title="Profile"><i class="fa-solid fa-user-pen"></i></a>
    <a href="/auth/logout" class="btn btn-sm btn-outline-danger" title="Logout"><i class="fa-solid fa-right-from-bracket"></i></a>
  </div>
</nav>

<div id="main-content" class="main-content">
  <header class="topbar">
    <button class="btn btn-sm btn-ghost sidebar-toggle" id="sidebarToggle">
      <i class="fa-solid fa-bars"></i>
    </button>
    <nav aria-label="breadcrumb" class="breadcrumb-nav">
      <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/dashboard">Home</a></li>
        <li class="breadcrumb-item active"><%= title %></li>
      </ol>
    </nav>
    <div class="topbar-right">
      <span class="badge bg-secondary"><%= appName %></span>
    </div>
  </header>

  <% if (flash.success && flash.success.length) { %>
  <div class="alert alert-success alert-dismissible fade show mx-4 mt-3" role="alert">
    <%- flash.success[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <% } %>
  <% if (flash.error && flash.error.length) { %>
  <div class="alert alert-danger alert-dismissible fade show mx-4 mt-3" role="alert">
    <%- flash.error[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <% } %>
  <% if (flash.info && flash.info.length) { %>
  <div class="alert alert-info alert-dismissible fade show mx-4 mt-3" role="alert">
    <%- flash.info[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <% } %>

  <main class="page-content">

<%- include('../partials/header', { title }) %>

<div class="d-flex align-items-center justify-content-between mb-4">
  <h2 class="page-title mb-0"><i class="fa-solid fa-key me-2"></i>API Keys</h2>
  <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
    <i class="fa-solid fa-plus me-1"></i>Generate Key
  </button>
</div>

<div class="card card-dark">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-dark table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Name</th><th>Prefix</th><th>Scopes</th><th>Owner</th><th>Last Used</th><th>Expires</th><th>Status</th><th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% keys.forEach(k => { %>
          <tr>
            <td class="fw-semibold"><%= k.name %></td>
            <td><code class="text-warning"><%= k.prefix %>…</code></td>
            <td>
              <% k.getScopes().forEach(s => { %>
              <span class="badge bg-dark text-info me-1"><%= s %></span>
              <% }) %>
            </td>
            <td class="text-muted"><%= k.user ? k.user.username : '—' %></td>
            <td class="text-muted small"><%= k.lastUsedAt ? moment(k.lastUsedAt).fromNow() : 'Never' %></td>
            <td class="text-muted small">
              <% if (!k.expiresAt) { %>
              <span class="badge bg-secondary">Never</span>
              <% } else if (k.isExpired()) { %>
              <span class="badge bg-danger">Expired</span>
              <% } else { %>
              <span class="badge bg-warning text-dark"><%= moment(k.expiresAt).fromNow() %></span>
              <% } %>
            </td>
            <td>
              <span class="badge bg-<%= k.isActive && !k.isExpired() ? 'success' : 'secondary' %>">
                <%= k.isActive && !k.isExpired() ? 'Active' : 'Revoked' %>
              </span>
            </td>
            <td class="text-end">
              <div class="btn-group btn-group-sm">
                <% if (k.isActive) { %>
                <form method="POST" action="/apikeys/<%= k.id %>/revoke">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn btn-outline-warning" title="Revoke"><i class="fa-solid fa-ban"></i></button>
                </form>
                <% } %>
                <form method="POST" action="/apikeys/<%= k.id %>/delete" onsubmit="return confirm('Delete this API key?')">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn btn-outline-danger" title="Delete"><i class="fa-solid fa-trash"></i></button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
          <% if (!keys.length) { %>
          <tr><td colspan="8" class="text-center text-muted py-4">No API keys yet. Generate your first key.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Create modal -->
<div class="modal fade" id="createModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-key me-2"></i>Generate API Key</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/apikeys/create">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Key Name <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control" placeholder="e.g. CI Pipeline" required maxlength="100" />
          </div>
          <div class="mb-3">
            <label class="form-label">Scopes</label>
            <div class="row g-2">
              <% ['read', 'write', 'delete', '*'].forEach(scope => { %>
              <div class="col-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="scopes" value="<%= scope %>" id="scope_<%= scope %>" <%= scope === 'read' ? 'checked' : '' %> />
                  <label class="form-check-label" for="scope_<%= scope %>"><code><%= scope %></code></label>
                </div>
              </div>
              <% }) %>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Expiry</label>
            <select name="expiresIn" class="form-select">
              <option value="never">Never</option>
              <option value="30">30 days</option>
              <option value="90">90 days</option>
              <option value="365">1 year</option>
            </select>
          </div>
          <div class="alert alert-warning small">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>The full key is shown only once after creation. Save it immediately.
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="fa-solid fa-key me-1"></i>Generate</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
